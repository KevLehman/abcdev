---
interface Entry { idx: number; slug: string; date: Date; tags: string[]; title: string; rt: string; }
interface Props { entries: Entry[]; }
const { entries } = Astro.props;
const iso = (d: Date) => d.toISOString().slice(0, 10);
const pad = (n: number) => String(n).padStart(3, '0');
const rtShort = (rt: string) => rt.replace(' min read', 'm').replace(/\s/g, '');

// Facets are the log's recurring themes: tags used on 2+ entries, most-used first,
// capped so the bar stays a tight index rather than a wall. One-off tags still show
// inline in each row — they just aren't a useful filter (they'd match a single row).
const counts = new Map<string, number>();
for (const e of entries) for (const t of e.tags) counts.set(t, (counts.get(t) ?? 0) + 1);
const tags = [...counts.entries()]
  .filter(([, c]) => c >= 2)
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .slice(0, 12)
  .map(([t]) => t);
---
<section class="listing">
  <div class="facetbar" data-facets hidden>
    <span class="facet-label eyebrow">tags</span>
    <span class="count" data-count aria-live="polite">{entries.length} entries</span>
    <div class="facet-list">
      <button type="button" class="facet" data-tag="" aria-pressed="true">all</button>
      {tags.map((t) => (
        <button type="button" class="facet" data-tag={t} aria-pressed="false">{t}</button>
      ))}
    </div>
  </div>
  <div class="listhead">
    <span>idx</span><span>date</span><span>rt</span><span>title — tags</span>
  </div>
  {entries.map((e) => (
    <a class="row" href={`/${e.slug}`} data-tags={e.tags.join(' ')}>
      <span class="idx">{pad(e.idx)}</span>
      <span>{iso(e.date)}</span>
      <span class="rt">{rtShort(e.rt)}</span>
      <span><span class="title">{e.title}</span> <span class="tags">{e.tags.map((t, i) => (<>{i > 0 && <>,<wbr /></>}{t}</>))}</span></span>
    </a>
  ))}
</section>
<script is:inline>
  // Client-side tag filter. The bar is server-rendered but hidden until this runs,
  // so no-JS visitors get the full list instead of dead buttons. The active tag
  // lives in the URL hash so a filtered view survives reload and can be shared.
  (() => {
    const bar = document.querySelector('[data-facets]');
    if (!bar) return;
    const rows = Array.from(document.querySelectorAll('.row[data-tags]'));
    const facets = Array.from(bar.querySelectorAll('.facet'));
    const count = bar.querySelector('[data-count]');
    const total = rows.length;

    const apply = (tag) => {
      let shown = 0;
      for (const r of rows) {
        const match = !tag || r.dataset.tags.split(' ').includes(tag);
        r.hidden = !match;
        if (match) shown++;
      }
      for (const f of facets) f.setAttribute('aria-pressed', String((f.dataset.tag || '') === tag));
      count.textContent = tag ? `${shown} of ${total}` : `${total} entries`;
      const next = tag ? `#${encodeURIComponent(tag)}` : location.pathname + location.search;
      history.replaceState(null, '', next);
    };

    for (const f of facets) f.addEventListener('click', () => apply(f.dataset.tag || ''));
    const known = new Set(facets.map((f) => f.dataset.tag || ''));
    const initial = decodeURIComponent(location.hash.slice(1));
    apply(known.has(initial) ? initial : '');
    bar.hidden = false;
  })();
</script>
<style>
  .listing { padding: 34px 0 20px; }
  .facetbar { display: flex; flex-wrap: wrap; align-items: baseline; gap: 10px 14px; padding: 0 10px 22px; }
  .facetbar[hidden] { display: none; }
  .facet-label { flex: none; }
  /* Full-width so the tokens always wrap inside the column rather than overflowing;
     the label and count sit together on the line above. */
  .facet-list { flex: 1 1 100%; min-width: 0; display: flex; flex-wrap: wrap; gap: 2px; }
  /* Facets speak the list's language: an active tag gets the same signal-blue
     inversion a row shows on hover, so filtering reads as selecting. */
  .facet { font-family: var(--font-mono); font-size: .82rem; line-height: 1; color: var(--slate);
    background: none; border: 0; padding: 6px 9px; cursor: pointer;
    transition: background .12s, color .12s; }
  .facet:hover { color: var(--signal); }
  .facet[aria-pressed="true"] { background: var(--signal); color: var(--on-signal); }
  .facet[aria-pressed="true"]:hover { color: var(--on-signal); }
  .count { flex: none; margin-left: auto; font-family: var(--font-mono); font-size: .72rem;
    letter-spacing: .04em; color: var(--slate); white-space: nowrap; }
  .listhead, .row { display: grid; grid-template-columns: 54px 118px 52px 1fr; gap: 18px; }
  .listhead { font-family: var(--font-mono); font-size: .72rem; letter-spacing: .1em;
    text-transform: uppercase; color: var(--slate); padding: 0 10px 12px; border-bottom: 1px solid var(--hairline); }
  .row { font-family: var(--font-mono); font-size: .84rem; align-items: baseline; padding: 15px 10px;
    border-bottom: 1px solid var(--hairline); color: var(--graphite); text-decoration: none;
    transition: background .12s, color .12s; }
  .row[hidden] { display: none; }
  .row:hover { background: var(--signal); color: var(--on-signal); }
  .row:hover .idx, .row:hover .rt, .row:hover .tags { color: var(--signal-tint); }
  .row:hover .title { color: var(--on-signal); }
  .idx, .rt, .tags { color: var(--slate); }
  /* The tag list is a comma-joined mono string with no spaces; <wbr> after each
     comma lets it wrap at tag boundaries on narrow screens, and anywhere is the
     fallback so a single long tag can never force horizontal overflow. */
  .tags { overflow-wrap: anywhere; }
  .title { font-family: var(--font-display); font-weight: 500; font-size: 1rem; }
  @media (max-width: 640px) {
    .listhead { display: none; }
    .row { grid-template-columns: auto auto 1fr; gap: 6px 12px; padding: 16px 10px; }
    .row > :nth-child(4) { grid-column: 1 / -1; }
    .title { font-size: 1.05rem; }
  }
</style>
